{
    "name": "college-portal-backend",
    "version": "1.0.0",
    "description": "Backend API for College eNOC Portal with Google OAuth, MySQL, and Email Service",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon --delay 500ms server.js",
        "seed": "node seed.js",
        "test": "jest --forceExit",
        "test:watch": "jest --watch --forceExit",
        "test:coverage": "jest --coverage --forceExit"
    },
    "keywords": [
        "noc",
        "college",
        "internship",
        "google-oauth",
        "mysql"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "google-auth-library": "^9.4.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.6.5",
        "nodemailer": "^6.9.7",
        "sequelize": "^6.35.2",
        "xlsx": "^0.18.5"
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "nodemon": "^3.0.2",
        "supertest": "^7.2.2"
    },
    "jest": {
        "testEnvironment": "node",
        "testMatch": ["**/tests/**/*.test.js"],
        "setupFiles": ["./tests/setup.js"],
        "testTimeout": 15000,
        "verbose": true,
        "forceExit": true
    }
}
