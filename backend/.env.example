# ================================================================
#  eNOC Portal — Backend Environment Variables (EXAMPLE)
#  Copy this file to backend/.env and fill in your values.
#  NEVER commit .env to git.
# ================================================================

# ── Server ───────────────────────────────────────────────────────
# Port where the backend API will run
# Frontend expects backend at http://localhost:5000 by default
# If you change this, also update js/config.js → API_BASE_URL
PORT=5000
NODE_ENV=development

# ── MySQL Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=college_portal
DB_USER=root
DB_PASSWORD=your_mysql_password
# Leave DB_PASSWORD blank if MySQL has no root password (XAMPP default)

# ── Google OAuth ─────────────────────────────────────────────────
# CRITICAL: This Client ID MUST match the one in js/google-auth.js
# Get from: https://console.cloud.google.com/apis/credentials
# See GOOGLE_OAUTH_SETUP.md for setup instructions
#
# Replace with your actual Client ID from Google Cloud Console:
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ── JWT ──────────────────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ya9F7kL2xQ8mZ4pR1tY6vN3sW0dH5cJ8
JWT_EXPIRE=7d

# ── Email (Nodemailer / Gmail) ───────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=eNOC Portal <noreply@charusat.edu.in>

# ── Frontend URL (CORS whitelist) ────────────────────────────────
# This is where the frontend is served from.
# Use http://localhost:8080 when running via start-portal.bat
# Use http://127.0.0.1:5500 when using VS Code Live Server
FRONTEND_URL=http://localhost:8080

# ── File Upload ──────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
# 5MB in bytes

# ── Domain Validation ────────────────────────────────────────────
# Email domain validation for CHARUSAT
# Students: must use @charusat.edu.in (or subdomains like @it.charusat.edu.in)
# Faculty/Admin: must use @charusat.ac.in (or subdomains like @ce.charusat.ac.in)
#
# These settings validate the domain type (edu/ac):
STUDENT_DOMAIN=edu
FACULTY_DOMAIN=ac
ADMIN_DOMAIN=ac
